# Supabase — required for content fetching
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — required for build-time server fetches (set in GitHub Secrets)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login uses Supabase Auth (email + password)
# Create a user at https://supabase.com → Authentication → Users → Add User
